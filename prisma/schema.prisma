generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model User {
  id Int  @id @default(autoincrement())
  name String? 
  phone String @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  wallet Wallet?
  transactions Transaction[]
  card BankCard[]

  @@index([id])
}

model Otp {
  id Int @id @default(autoincrement())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone,code])
}

model Wallet{
  user_id Int @id
  amount    Int  @default(0) 
  gold_amount Int @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user User @relation(fields: [user_id], references: [id],onDelete: Cascade)

  @@index([user_id])
}

model Transaction {
  id Int @id @default(autoincrement())
  total_amount Int
  gold_amount Int?
  price_per_milligram Int?
  created_at DateTime @default(now())
  type TransactionType
  payment_type PaymentType?
  status TransactionStatus @default(pending)
  authority String? @unique

  bank_card_id Int?
  bank_card BankCard? @relation(fields: [bank_card_id], references: [id])

  user_id Int
  user User @relation(fields: [user_id], references: [id],onDelete: Cascade)

  @@index([user_id, status, type, authority, bank_card_id])
}

enum TransactionStatus {
  success
  pending
  failed
}

enum TransactionType {
  buy
  sell
  withdraw
  deposit
}

enum PaymentType {
  gateway
  wallet
}

model GoldPrice {
  id         Int      @id @default(autoincrement())
  price      Int
  created_at DateTime @default(now())

  @@index([id])
}

model BankCard {
  id         Int      @id @default(autoincrement())
  card_number String @unique
  shaba String @unique
  bank_name String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  transactions Transaction[]
  
  user_id Int
  user User @relation(fields: [user_id], references: [id],onDelete: Cascade)

  @@index([id, user_id])
}