generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model User {
  id Int  @id @default(autoincrement())
  name String? 
  phone String @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  wallet Wallet?
  transactions Transaction[]
}

model Otp {
  id Int @id @default(autoincrement())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone,code])
}

model Wallet{
  user_id Int @id
  amount    Int  @default(0) 
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user User @relation(fields: [user_id], references: [id],onDelete: Cascade)
}

model Transaction {
  id Int @id @default(autoincrement())
  total_amount Int
  gold_amount Int
  price_per_milligram Int
  created_at DateTime @default(now())
  type TransactionType

  user_id Int
  user User @relation(fields: [user_id], references: [id],onDelete: Cascade)
}

enum TransactionType {
  buy
  sell
  withdraw
}

model GoldPrice {
  id         Int      @id @default(autoincrement())
  price      Int
  created_at DateTime @default(now())
}